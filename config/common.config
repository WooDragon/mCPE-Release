# =============================================================================
# Common Seed Configuration — shared across ALL devices
# =============================================================================
# 这是 5+ 个设备种子配置的严格交集(逐行完全相同的部分)。
# 拼装契约: cat config/common.config devices/$DEVICE/seed.config > .config
# 然后 'make defconfig' 展开为完整配置。
#
# 铁律: 本文件不得含任何架构/平台相关项(无 TARGET 平台符号、无 GRUB/VMDK、
#       无平台专属 kmod)。架构相关项一律下沉到 devices/<dev>/seed.config。
# =============================================================================

# Base System
CONFIG_TARGET_ROOTFS_TARGZ=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
# CONFIG_TARGET_ROOTFS_EXT4FS is not set
CONFIG_TARGET_KERNEL_PARTSIZE=32
CONFIG_TARGET_ROOTFS_PARTSIZE=1024

# Kernel Security — Landlock LSM
# KERNEL_SECURITY 有 OpenWrt Config-kernel.in 入口, 走正常 seed 通道。
# SECURITYFS / SECURITY_LANDLOCK / LSM 列表无入口 (或入口有 SELinux 前置依赖),
# 会被 OpenWrt defconfig 静默剥掉; 改由 diy-part2.sh 直注 target/linux/generic/config-6.6。
CONFIG_KERNEL_SECURITY=y

# Build Acceleration (host-side ccache; arch-neutral, 不影响固件内容)
# CONFIG_DEVEL 必须置顶: 上游 config/Config-devel.in 把 CCACHE 的 prompt 声明为
# `bool "Use ccache" if DEVEL`, DEVEL 关闭时 CCACHE prompt 不可见, make defconfig
# 会静默剔除 CONFIG_CCACHE=y 回退默认 n, 导致 ccache 全程空转(详见 issue #25)。
# DEVEL 仅解锁 host 侧开发者选项可见性, arch-neutral, 不改变固件内容。
CONFIG_DEVEL=y
CONFIG_CCACHE=y

# Firmware Version (公共部分; VERSION_CODE / VERSION_HWREV 在各设备 seed 内)
CONFIG_VERSIONOPT=y
CONFIG_VERSION_DIST="MCPE"
CONFIG_VERSION_NUMBER="251228"
CONFIG_VERSION_FILENAMES=y
CONFIG_VERSION_CODE_FILENAMES=y

# LuCI
# CONFIG_PACKAGE_luci is not set
CONFIG_PACKAGE_luci-nginx=y
# CONFIG_PACKAGE_uhttpd is not set
# CONFIG_PACKAGE_uhttpd-mod-ubus is not set
# CONFIG_PACKAGE_luci-ssl-openssl is not set
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# LuCI Applications (Core)
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-sqm=y
CONFIG_PACKAGE_luci-app-wireguard=y
CONFIG_PACKAGE_luci-app-frpc=y
CONFIG_PACKAGE_luci-app-netdata=y
CONFIG_PACKAGE_luci-app-nlbwmon=y
CONFIG_PACKAGE_luci-app-wrtbwmon=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-mosdns=y
CONFIG_PACKAGE_luci-app-arpbind=y
CONFIG_PACKAGE_luci-app-eqos=y
CONFIG_PACKAGE_luci-app-filetransfer=y
CONFIG_PACKAGE_luci-app-tinyproxy=y
CONFIG_PACKAGE_luci-app-pushbot=y

# Docker
CONFIG_PACKAGE_dockerd=y
CONFIG_PACKAGE_docker=y
CONFIG_PACKAGE_docker-compose=y

# Flow Offloading
CONFIG_PACKAGE_kmod-nft-offload=y

# Network Utilities
CONFIG_PACKAGE_ip-full=y
# CONFIG_BUSYBOX_DEFAULT_IP is not set
CONFIG_PACKAGE_dnsmasq-full=y
# CONFIG_PACKAGE_dnsmasq is not set
CONFIG_BUSYBOX_CONFIG_TELNET=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_tcping=y
CONFIG_PACKAGE_iftop=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_fping=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_screen=y

# Explicitly Disabled
# CONFIG_PACKAGE_luci-app-turboacc is not set
# CONFIG_PACKAGE_luci-app-bypass is not set
# CONFIG_PACKAGE_luci-app-vssr is not set
# CONFIG_PACKAGE_luci-app-ssr-plus is not set
# CONFIG_PACKAGE_luci-app-passwall is not set
# CONFIG_PACKAGE_luci-app-passwall2 is not set
# CONFIG_PACKAGE_kmod-shortcut-fe is not set
# CONFIG_PACKAGE_kmod-shortcut-fe-cm is not set
# CONFIG_PACKAGE_strongswan is not set
# CONFIG_PACKAGE_ruby is not set
# CONFIG_PACKAGE_collectd is not set
# CONFIG_PACKAGE_autosamba is not set
# CONFIG_PACKAGE_luci-app-samba4 is not set
# CONFIG_PACKAGE_vsftpd is not set
# CONFIG_PACKAGE_luci-app-vsftpd is not set
# CONFIG_PACKAGE_luci-app-vlmcsd is not set
# CONFIG_PACKAGE_luci-app-zerotier is not set
# CONFIG_PACKAGE_luci-app-qbittorrent is not set
# CONFIG_PACKAGE_luci-app-qbittorrent-simple is not set
# CONFIG_PACKAGE_gcc is not set
