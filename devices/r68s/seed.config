# Device: NanoPi R68S (Rockchip armv8)
# 注意: R68S 的上游 device 符号厂商前缀是 lunzn_fastrhino, 非 friendlyarm。
# 旧分支误用 friendlyarm_nanopi-r68s (无效符号), 导致 defconfig 静默回退、
# 实际编出 ariaboard_photonicat 固件。此处修正为上游 v24.10.4 真实符号。
CONFIG_TARGET_rockchip=y
CONFIG_TARGET_rockchip_armv8=y
CONFIG_TARGET_rockchip_armv8_DEVICE_lunzn_fastrhino-r68s=y
CONFIG_VERSION_CODE="04"
CONFIG_VERSION_HWREV="R68S"

