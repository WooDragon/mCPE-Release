# Device: NanoPi R5S + outdoor-backup feed (Rockchip armv8)
# 硬件与 r5s 相同; 差异 = outdoor feed(见 pre-feeds.sh)+ 存储包 + 版本标识
CONFIG_TARGET_rockchip=y
CONFIG_TARGET_rockchip_armv8=y
CONFIG_TARGET_rockchip_armv8_DEVICE_friendlyarm_nanopi-r5s=y
CONFIG_VERSION_CODE="05"
CONFIG_VERSION_HWREV="R5S-OUT"

# Storage / Filesystem (outdoor 变体专属)
CONFIG_PACKAGE_kmod-fs-btrfs=y
CONFIG_PACKAGE_btrfs-progs=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_smartmontools=y

# Wireless (mt7922 via M.2 PCIe)
CONFIG_PACKAGE_kmod-mt7921e=y
CONFIG_PACKAGE_mt7922-firmware=y
CONFIG_PACKAGE_wpad-openssl=y
# CONFIG_PACKAGE_wpad-basic-wolfssl is not set
# CONFIG_PACKAGE_wpad-basic-mbedtls is not set
