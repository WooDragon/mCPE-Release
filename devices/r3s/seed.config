# Device: NanoPi R3S (Rockchip armv8, RK3566)
# 上游 v24.10.4 已原生支持; device 符号 friendlyarm_nanopi-r3s。
# VERSION_CODE 取空闲值 06 (现有 03=R2S, 04=R5S/R68S, 05=R5S-OUT/X86)。
CONFIG_TARGET_rockchip=y
CONFIG_TARGET_rockchip_armv8=y
CONFIG_TARGET_rockchip_armv8_DEVICE_friendlyarm_nanopi-r3s=y
CONFIG_VERSION_CODE="06"
CONFIG_VERSION_HWREV="R3S"

# First-boot auto-expand rootfs (preinit hook: 79_expand_rootfs)
# f2fsck: fsck.f2fs + resize.f2fs; sfdisk: expand p2; losetup: unmounted f2fs view (-o offset)
CONFIG_PACKAGE_f2fsck=y
CONFIG_PACKAGE_sfdisk=y
CONFIG_PACKAGE_losetup=y
