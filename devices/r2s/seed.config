# Device: NanoPi R2S (Rockchip armv8)
CONFIG_TARGET_rockchip=y
CONFIG_TARGET_rockchip_armv8=y
CONFIG_TARGET_rockchip_armv8_DEVICE_friendlyarm_nanopi-r2s=y
CONFIG_VERSION_CODE="03"
CONFIG_VERSION_HWREV="R2S"

# First-boot auto-expand rootfs (preinit hook: 79_expand_rootfs)
# f2fsck: fsck.f2fs + resize.f2fs; sfdisk: expand partition; partx-utils: partx
CONFIG_PACKAGE_f2fsck=y
CONFIG_PACKAGE_sfdisk=y
CONFIG_PACKAGE_partx-utils=y
